# CapyCMS / Blog setup (non-secret)
#
# Option 1: commit a `.env` with at least CAPYCMS_TEMPLATE_ID.
# Option 2: set `CAPYCMS_TEMPLATE_ID` as a GitHub Actions variable.
#
# Template id: one of the folders in `src/templates/`
CAPYCMS_TEMPLATE_ID=blank-canvas

# Optional metadata used by `scripts/setup.ts`
CAPYCMS_BLOG_TITLE="My Blog"
CAPYCMS_BLOG_AUTHOR="Author"
CAPYCMS_BLOG_DESCRIPTION="A blog powered by CapyCMS"

# Optional: custom domain for GitHub Pages (writes/updates `public/CNAME`)
CAPYCMS_CUSTOM_DOMAIN=
